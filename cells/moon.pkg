import {
  "dowdiness/incr/types" @incr_types,
  "moonbitlang/core/hashmap",
  "moonbitlang/core/hashset",
  "moonbitlang/core/priority_queue",
}
// Suppress unused_mut (warning 15) for PullMemoData/PullSignalData fields:
// Some `mut` fields are only written in whitebox-test compilation (which
// includes *_wbtest.mbt), so the source-only check phase would incorrectly
// flag them as unused-mut.

warnings = "-15"
